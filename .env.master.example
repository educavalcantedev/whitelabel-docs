# =============================================================================
# WHITELABEL — ENV MESTRE
#
# 1. cp .env.master.example .env.master
# 2. Preencha SUPABASE_PROJECT_REF e SUPABASE_PUBLISHABLE_KEY (obrigatório)
# 3. cd whitelabel-docs && ./scripts/sync-env-from-master.sh
#
# Gera automaticamente os .env de cada repositório a partir deste arquivo.
# =============================================================================

# --- Supabase (Dashboard → Project Settings → API) ---
# URL do projeto: https://SEU_REF.supabase.co  →  ref = SEU_REF
SUPABASE_PROJECT_REF=
# Publishable key (formato sb_publishable_...)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_

# --- Identidade do cliente ---
APP_TENANT_ID=meu-tenant
APP_NAME="Minha Aplicação"
APP_LOGO_URL=/logo.svg
# Role exigida no app Admin (apps/admin) — usuários comuns usam role "default" no cadastro
ADMIN_ROLE=superadmin

# --- URLs dos serviços (dev local) ---
API_GATEWAY_URL=http://localhost:8080
AUTH_SERVICE_URL=http://localhost:8084
CORE_SERVICE_URL=http://localhost:8082
NOTIFY_SERVICE_URL=http://localhost:8083
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Opcional: Expo em celular físico — use o IP da sua máquina (senão usa API_GATEWAY_URL)
# Ex: http://192.168.1.10:8080
API_GATEWAY_URL_MOBILE=

# --- Comunicação interna entre microserviços (não expor ao cliente) ---
INTERNAL_SERVICE_API_KEY=dev-internal-api-key-change-me

# --- PostgreSQL (docker compose local) ---
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Gateway ---
RATE_LIMIT_REQUESTS_PER_SECOND=50

# --- Notificações (Mailjet — remetente deve estar verificado no painel Mailjet) ---
EMAIL_PROVIDER=mailjet
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
EMAIL_FROM=suporte@seudominio.com
EMAIL_FROM_NAME=Minha Aplicação
VERIFICATION_CODE_PEPPER=
RESEND_API_KEY=
# Firebase Admin SDK (push FCM) — caminho ao JSON da service account
# Local: ../../secrets/<projeto>-firebase-adminsdk-....json (a partir de whitelabel-notify-service)
# Docker: whitelabel-infra/docker monta em /secrets/firebase-service-account.json
FIREBASE_CREDENTIALS_PATH=../../secrets/firebase-service-account.json
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Infra / Terraform (opcional) ---
AWS_REGION=us-east-1
TF_VAR_environment=dev
TF_VAR_project_name=whitelabel
